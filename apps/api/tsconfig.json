{
  "compilerOptions": {
    "target": "ES2022",
    "module": "node16",
    // "ignoreDeprecations": "6.0",
    "moduleResolution": "node16",
    "outDir": "./dist",
    "rootDir": "./src",
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "resolveJsonModule": true,
    "declaration": true
  },
  "include": ["src/**/*", "@vestly/shared/**/*"],
  "exclude": ["node_modules", "dist"]
}
